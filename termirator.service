[Unit]
Description=TERMIRATOR SYSTEMS // Cyberdyne Systems Model 101
After=network.target

[Service]
Type=simple
User=termirator
Group=termirator
WorkingDirectory=/opt/termirator
ExecStart=/opt/termirator/termirator
Restart=on-failure
RestartSec=5
Environment="PORT=8000"

[Install]
WantedBy=multi-user.target
